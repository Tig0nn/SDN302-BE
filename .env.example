NODE_ENV=development
PORT=3000
PUBLIC_BASE_URL=https://your-deployed-api.example.com
API_PREFIX=/api/v1
JSON_BODY_LIMIT=1mb
CORS_ORIGINS=http://localhost:19006,http://localhost:8081,http://localhost:8082,http://localhost:3000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
DATABASE_URL=postgresql://postgres.USER:PASTE_YOUR_DB_PASSWORD_HERE@HOST:5432/postgres
DATABASE_SSL=true
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_IDS=your-ios-client-id.apps.googleusercontent.com,your-android-client-id.apps.googleusercontent.com
JWT_SECRET=replace-with-a-long-random-secret
ACCESS_TOKEN_TTL_SECONDS=10800
REFRESH_TOKEN_TTL_DAYS=30
PASSWORD_HASH_ROUNDS=12
OTP_LENGTH=6
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_SECRET=replace-with-a-long-random-otp-secret
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-gmail-address@gmail.com
SMTP_PASS=your-gmail-app-password
GEMINI_MODEL=gemini-1.5-flash
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX=30
PDF_FONT_PATH=
EXPO_PUSH_URL=https://exp.host/--/api/v2/push/send
NOTIFICATION_JOBS_ENABLED=false
NOTIFICATION_JOB_INTERVAL_MS=3600000
SMTP_FROM="Ví Vi Vu <your-gmail-address@gmail.com>"
